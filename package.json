{
  "name": "anyaba_chibuike_ui_garden",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "styled-components": "^6.3.10",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --runInBand",
    "eject": "react-scripts eject",
    "lint": "eslint src .storybook --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src .storybook --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier \".github/workflows/*.{yml,yaml}\" \".storybook/**/*.{js,jsx,ts,tsx}\" \"public/**/*.{html,json}\" \"src/**/*.{js,jsx,ts,tsx,css}\" \"*.{json,md}\" \".*ignore\" \".prettierrc\" \"Dockerfile\" \"nginx.conf\" --write --ignore-unknown",
    "format:check": "prettier \".github/workflows/*.{yml,yaml}\" \".storybook/**/*.{js,jsx,ts,tsx}\" \"public/**/*.{html,json}\" \"src/**/*.{js,jsx,ts,tsx,css}\" \"*.{json,md}\" \".*ignore\" \".prettierrc\" \"Dockerfile\" \"nginx.conf\" --check --ignore-unknown",
    "validate": "npm run format:check && npm run lint && npm run test:ci",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --check",
      "eslint --max-warnings=0"
    ],
    "*.{css,md,json,yml,yaml}": [
      "prettier --check"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:storybook/recommended"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-onboarding": "^10.2.10",
    "@storybook/preset-create-react-app": "^10.2.10",
    "@storybook/react": "^10.2.10",
    "@storybook/react-webpack5": "^10.2.10",
    "@types/styled-components": "^5.1.36",
    "eslint-plugin-storybook": "^10.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "storybook": "^10.2.10",
    "webpack": "^5.105.2"
  }
}
